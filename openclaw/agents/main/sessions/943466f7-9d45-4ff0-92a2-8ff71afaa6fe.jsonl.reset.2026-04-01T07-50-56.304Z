{"type":"message","id":"41b527c2","parentId":"b4f689c7","timestamp":"2026-03-31T03:24:12.037Z","message":{"role":"toolResult","toolCallId":"tool_mtAnszHIYkpk9QnKWUixvvlJ","toolName":"read","content":[{"type":"text","text":"\"\"\"Motor arm driver ROS2 interface adapter.\n\n\nThis module is intended to be imported and used from code that already\ninitialised rclpy and created a Node instance.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport threading\nimport copy\nimport time\nfrom typing import List, Optional\n\nimport rclpy\nfrom rclpy.node import Node\nfrom rclpy.action import ActionClient\nfrom std_msgs.msg import Header\n\nfrom arm_control_interface.srv import SetPower\nfrom arm_control_interface.msg import ArmState, ArmRtCtrlCmd\nfrom arm_control_interface.action import ArmRtCtrl\n\n\nclass MotorArmDriver:\n\t\"\"\"Adapter exposing power, state and real-time control interfaces.\n\n\tThe driver re-uses an existing ROS2 `Node` instance passed at\n\tconstruction time so it integrates into the user's node (e.g. `VRSystem`).\n\t\"\"\"\n\n\tdef __init__(self, node: Node, namespace: str = \"wy_robot1\", rt_freq: float = 50.0):\n\t\tself.node = node\n\t\tself.ns = namespace.strip('/')\n\t\tself._rt_freq = float(rt_freq)\n\n\t\t# State storage\n\t\tself._state_lock = threading.Lock()\n\t\tself._latest_state: Optional[ArmState] = None\n\n\t\t# event set whenever a state message is received\n\t\tself._state_event = threading.Event()\n\n\t\t# Target angles (externally set) with lock\n\t\tself._target_lock = threading.Lock()\n\t\tself._target_angles: List[float] = []\n\n\t\t# ROS interfaces (created on start)\n\t\tself._state_sub = None\n\t\tself._rt_pub = None\n\t\tself._power_client = None\n\t\tself._rt_action_client: Optional[ActionClient] = None\n\n\t\t# RT publish thread\n\t\tself._rt_thread: Optional[threading.Thread] = None\n\t\tself._rt_thread_stop = threading.Event()\n\n\t\t# RT action lifecycle\n\t\tself._rt_goal_handle = None\n\t\tself._rt_active = False\n\n\t\t# Flags\n\t\tself._started = False\n\n\t\t# track last seen arm_mode to log changes\n\t\tself._last_arm_mode: Optional[int] = None\n\t\tself._mode_map = {\n\t\t\t100: '初始化',\n\t\t\t101: '待机',\n\t\t\t102: '开机中',\n\t\t\t103: '关机中',\n\t\t\t104: '空闲',\n\t\t\t105: 'MoveJ',\n\t\t\t106: 'MoveL',\n\t\t\t107: 'MoveCart',\n\t\t\t109: '实时控制',\n\t\t\t120: '告警',\n\t\t}\n\t\tself.__init_success = False\n\t\tself.node.get_logger().info(f\"MotorArmDriver initialized with namespace '{self.ns}' and RT frequency {self._rt_freq} Hz\")\n\n\tdef _topic(self, name: str) -> str:\n\t\treturn f\"/{self.ns}/{name}\"\n\n\tdef start(self) -> None:\n\t\t\"\"\"Create subscriptions/publishers/clients and start RT publish thread.\"\"\"\n\t\tif self._started:\n\t\t\treturn\n\t\t# subscriptions/publishers/clients\n\t\tself._state_sub = self.node.create_subscription(\n\t\t\tArmState, self._topic('A6_state'), self._on_state, 10\n\t\t)\n\t\tself._rt_pub = self.node.create_publisher(ArmRtCtrlCmd, self._topic('A6_rt_control_cmd'), 10)\n\t\tself._power_client = self.node.create_client(SetPower, self._topic('A6_set_power'))\n\t\tself._rt_action_client = ActionClient(self.node, ArmRtCtrl, self._topic('A6_rt_control_action'))\n\n\t\tself._rt_thread_stop.clear()\n\t\tself._rt_thread = threading.Thread(target=self._rt_publish_loop, daemon=True)\n\t\tself._rt_thread.start()\n\n\t\tself._started = True\n\n\tdef stop(self) -> None:\n\t\t\"\"\"Stop background thread and tear down references (node-owned resources remain).\"\"\"\n\t\tif not self._started:\n\t\t\treturn\n\t\tself.stop_rt_control()\n\t\tself._rt_thread_stop.set()\n\t\tif self._rt_thread is not None:\n\t\t\tself._rt_thread.join(timeout=1.0)\n\n\t\tif self._executor_thread is not None:\n\t\t\tself._executor_thread.join(timeout=1.0)\n\t\tself._executor_thread = None\n\t\tself._started = False\n\n\tdef _on_state(self, msg: ArmState) -> None:\n\t\twith self._state_lock:\n\t\t\tself._latest_state = copy.deepcopy(msg)\n\n\t\ttry:\n\t\t\tmode = int(msg.arm_mode)\n\t\texcept Exception:\n\t\t\tmode = None\n\t\tif mode is not None and mode != self._last_arm_mode:\n\t\t\tprev = self._mode_map.get(self._last_arm_mode, str(self._last_arm_mode)) if self._last_arm_mode is not None else 'None'\n\t\t\tcurr = self._mode_map.get(mode, str(mode))\n\t\t\ttry:\n\t\t\t\tself.node.get_logger().info(f\"Arm mode change: {prev} -> {curr}\")\n\t\t\texcept Exception:\n\t\t\t\tprint(f\"Arm mode change: {prev} -> {curr}\")\n\t\t\tself._last_arm_mode = mode\n\t\ttry:\n\t\t\tself._state_event.set()\n\t\texcept Exception:\n\t\t\tpass\n\n\tdef get_latest_state(self) -> Optional[ArmState]:\n\t\twith self._state_lock:\n\t\t\treturn copy.deepcopy(self._latest_state) if self._latest_state is not None else None\n\n\tdef get_current_joint_angles(self) -> List[float]:\n\t\tst = self.get_latest_state()\n\t\tif st is None:\n\t\t\treturn []\n\t\treturn list(st.joint_angles)\n\n\t# ---- Power service ----\n\tdef set_power(self, enable: bool, timeout: float = 2.0) -> tuple[bool, str]:\n\t\t\"\"\"Call the `arm_set_power` service to enable/disable arm power.\n\n\t\tReturns (success, error_message).\n\t\t\"\"\"\n\t\tif self._power_client is None:\n\t\t\traise RuntimeError('Driver not started; call start() first')\n\n\t\tself.node.get_logger().info(f'Setting power to {\"ON\" if enable else \"OFF\"} timeout={timeout:.1f}s')\n\t\twaited = 0.0\n\t\tpoll = 0.05\n\t\twhile not self._power_client.wait_for_service(timeout_sec=poll):\n\t\t\twaited += poll\n\t\t\tif waited >= timeout:\n\t\t\t\treturn False, 'service_unavailable'\n\n\t\treq = SetPower.Request()\n\t\treq.power_enable = bool(enable)\n\t\tfut = self._power_client.call_async(req)\n\n\t\t# wait for response without calling spin functions (external spinner may run)\n\t\tdone = threading.Event()\n\t\tfut.add_done_callback(lambda _f, ev=done: ev.set())\n\t\tif not done.wait(timeout):\n\t\t\treturn False, 'call_timeout'\n\t\tif fut.result() is None:\n\t\t\treturn False, 'call_failed'\n\t\tres = fut.result()\n\t\t# direct field access to response fields\n\t\treturn bool(res.success), res.error\n\n\tdef ExitArmMotorControl(self) -> tuple[bool, str]:\n\t\tself.set_power(False, timeout=1.0)\n\t\tok, err = self.set_power(False, timeout=1.0)\n\t\tif not ok:\n\t\t\treturn False, '关机失败'\n\t\tself.stop_rt_control()\n\t\treturn True, ''\n\n\tdef initialize_power_and_wait(self, power_enable: bool = True, timeout: float = 10.0) -> tuple[bool, str]:\n\t\tself.node.get_logger().info('Initializing power and waiting for valid state...')\n\t\tif not self._started:\n\t\t\tself.start()\n\n\t\tself._state_event.clear()\n\n\t\tok, err = True, ''\n\t\tif power_enable:\n\t\t\tok, err = self.set_power(True, timeout=1.0)\n\t\t\tif not ok:\n\t\t\t\treturn False, f'set_power_failed:{err}'\n\t\t\telse:\n\t\t\t\tself.set_power(True, timeout=1.0)\n\n\t\tstart = time.time()\n\t\twhile rclpy.ok():\n\t\t\tremaining = timeout - (time.time() - start)\n\t\t\tif remaining <= 0:\n\t\t\t\treturn False, 'state_wait_timeout'\n\t\n\t\t\tif not self._state_event.wait(remaining):\n\t\t\t\treturn False, 'state_wait_timeout'\n\t\t\t\n\t\t\tself._state_event.clear()\n\t\t\tst = self.get_latest_state()\n\t\t\tif st is None:\n\t\t\t\tcontinue\n\t\t\tvalid = (len(st.joint_angles) >= 6 and st.arm_mode == 104)\n\t\t\tif valid:\n\t\t\t\tif self.__JudgeRtControlStatus():\n\t\t\t\t\tself.node.get_logger().info('Arm state valid and real-time control already active')\n\t\t\t\t\treturn True, 'already_ok'\n\t\t\t\tok, msg = self.start_rt_control('MotionJoint')\n\t\t\t\tif not ok:\n\t\t\t\t\treturn False, f'start_rt_failed:{msg}'\n\t\t\t\treturn True, 'ok'\n\tdef __JudgeRtControlStatus(self) -> bool:\n\t\treturn self._rt_active and self._rt_goal_handle is not None\n\n\tdef start_rt_control(self, rt_control_type: str = 'MotionJoint', timeout: float = 2.0) -> tuple[bool, str]:\n\t\t\"\"\"Send goal to ArmRtCtrl action to begin real-time control session.\"\"\"\n\t\t# wait for server\n\t\twaited = 0.0\n\t\tpoll = 0.05\n\t\twhile not self._rt_action_client.wait_for_server(timeout_sec=poll):\n\t\t\twaited += poll\n\t\t\tif waited >= timeout:\n\t\t\t\treturn False, 'action_server_unavailable'\n\n\t\tgoal_msg = ArmRtCtrl.Goal()\n\t\tgoal_msg.rt_control_type = str(rt_control_type)\n\n\t\tsend_goal_future = self._rt_action_client.send_goal_async(goal_msg)\n\t\tdone = threading.Event()\n\t\tsend_goal_future.add_done_callback(lambda _f, ev=done: ev.set())\n\t\tif not done.wait(timeout):\n\t\t\treturn False, 'send_goal_timeout'\n\t\tgoal_handle = send_goal_future.result()\n\t\tif not goal_handle.accepted:\n\t\t\treturn False, 'goal_rejected'\n\t\tself._rt_goal_handle = goal_handle\n\t\tself._rt_active = True\n\t\tresult_future = goal_handle.get_result_async()\n\t\tresult_future.add_done_callback(self._rt_result_done_cb)\n\t\tself.node.get_logger().info('Real-time control goal accepted, session started')\n\t\treturn True, 'accepted'\n\n\tdef stop_rt_control(self, timeout: float = 2.0) -> tuple[bool, str]:\n\t\t\"\"\"Send a stop request for realtime control by sending a 'Stop' goal.\n\n\t\tThe exact semantics of stopping depend on the controller implementation.\n\t\t\"\"\"\n\t\t# If there is an active goal, request cancel; otherwise request Stop goal\n\t\tif self._rt_goal_handle is not None:\n\t\t\tself.node.get_logger().info('Requesting real-time control cancel...')\n\t\t\tcancel_future = self._rt_goal_handle.cancel_goal_async()\n\t\t\tdone = threading.Event()\n\t\t\tcancel_future.add_done_callback(lambda _f, ev=done: ev.set())\n\t\t\tif not done.wait(timeout):\n\t\t\t\treturn False, 'cancel_timeout'\n\t\t\tself._rt_active = False\n\t\t\tself._rt_goal_handle = None\n\t\t\tself.node.get_logger().info('Real-time control cancel requested')\n\t\t\treturn True, 'cancel_requested'\n\t\treturn True, 'no_active_goal'\n\n\tdef _rt_result_done_cb(self, future):\n\t\tself.node.get_logger().info('Real-time control action completed')\n\t\ttry:\n\t\t\tres = future.result().result\n\t\t\tself.node.get_logger().info(f'Action result error_location: {res.error_location}, error_description: {res.error_description} error_code:{res.error_code.value}')\n\t\texcept Exception as ex:\n\t\t\tself.node.get_logger().info(f'control action result exception {ex}')\n\t\t\tres = None\n\t\tself._rt_active = False\n\t\tself._rt_goal_handle = None\n\n\tdef set_target_angles(self, angles: List[float]) -> None:\n\t\twith self._target_lock:\n\t\t\tself._target_angles = list(angles)\n\n\tdef __get_target_angles(self) -> List[float]:\n\t\twith self._target_lock:\n\t\t\treturn list(self._target_angles)\n\t\t\n\tdef set_init_success(self, success: bool, angles) -> None:\n\t\tif success:\n\t\t\twith self._target_lock:\n\t\t\t\tself._target_angles = list(angles)\n\t\tself.__init_success = success\n\n\tdef _rt_publish_loop(self) -> None:\n\t\tloop_period = 1.0 / max(1.0, float(self._rt_freq))\n\t\tnext_loop_time = time.perf_counter()\n\t\twhile not self._rt_thread_stop.is_set():\n\t\t\tnext_loop_time += loop_period\n\t\t\tnow = time.perf_counter()\n\t\t\tsleep_time = next_loop_time - now\n\t\t\tif sleep_time > 0:\n\t\t\t\ttime.sleep(sleep_time)\n\t\t\telse: \n\t\t\t\tnext_loop_time = now\n\t\t\tif not self._rt_active or self.__init_success is False:\n\t\t\t\tcontinue\n\t\t\t# prepare message\n\t\t\tangles = self.__get_target_angles()\n\t\t\tmsg = ArmRtCtrlCmd()\n\t\t\tmsg.header = Header()\n\t\t\ttry:\n\t\t\t\tnow = self.node.get_clock().now()\n\t\t\t\tmsg.header.stamp = now.to_msg()\n\t\t\texcept Exception:\n\t\t\t\tpass\n\t\t\tmsg.joint_angles = list(angles)\n\t\t\ttry:\n\t\t\t\tif self._rt_pub is not None:\n\t\t\t\t\tself._rt_pub.publish(msg)\n\t\t\texcept Exception:\n\t\t\t\tpass\n\n\n"}],"isError":false,"timestamp":1774927452029}}
{"type":"message","id":"0e45f64a","parentId":"41b527c2","timestamp":"2026-03-31T03:25:57.998Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"                       现在我明白了。机械臂控制不是直接用PallasSDK，而是通过ROS2接口：\n\n1. 使用`MotorArmDriver`类\n2. 通过ROS2话题和服务控制：\n   - `/wy_robot1/A6_state` - 状态订阅\n   - `/wy_robot1/A6_rt_control_cmd` - 实时控制命令发布\n   - `/wy_robot1/A6_set_power` - 电源服务\n   - `/wy_robot1/A6_rt_control_action` - 实时控制动作\n\n让我创建一个使用ROS2接口的脚本来控制机械臂。","thinkingSignature":""},{"type":"text","text":"    明白了！机械臂通过ROS2接口控制，不是直接用SDK。让我创建一个使用ROS2的脚本："},{"type":"toolCall","id":"tool_ba4r2bU1dOP4SG9NticmEU89","name":"write","arguments":{}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"kimi","model":"kimi-code","usage":{"input":36323,"output":1964,"cacheRead":0,"cacheWrite":0,"totalTokens":38287,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774927452044,"responseId":"msg_bsVNL0nIDoMgWwtHWLjIg097"}}
