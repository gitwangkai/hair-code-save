{"type":"message","id":"1d136f0c","parentId":"038d6a18","timestamp":"2026-03-31T03:21:04.387Z","message":{"role":"toolResult","toolCallId":"tool_BtGeoEFiiC5T9bI0W01KhH35","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n海尔机器人控制系统综合测试脚本\n测试 README_KEY_CONTROL.md 中的各个功能模块\n\n使用方法:\n    source /opt/ros/humble/setup.bash\n    source ~/Haier_robot_ws/install/setup.bash\n    python3 test_robot_control.py\n\n注意: 需要在机器人运行时执行，部分测试需要硬件支持\n\"\"\"\n\nimport sys\nimport os\n\n# 修复NumPy兼容性问题 - 禁用cv_bridge\nos.environ['ROS_PYTHON_LOG_LEVEL'] = 'warning'\n\nimport numpy as np\nimport cv2\n\n# 强制禁用cv_bridge，使用纯Python解析\nCV_BRIDGE_AVAILABLE = False\n\nimport rclpy\nfrom rclpy.node import Node\nfrom sensor_msgs.msg import Image, LaserScan, Imu, JointState, BatteryState\nfrom geometry_msgs.msg import Twist, PoseStamped\nfrom nav_msgs.msg import Odometry\nfrom std_msgs.msg import Float32, String, Empty\nfrom can_msgs.msg import Frame\nimport time\n\n\nclass RobotControlTester(Node):\n    def __init__(self):\n        super().__init__('robot_control_tester')\n        \n        if CV_BRIDGE_AVAILABLE:\n            self.bridge = CvBridge()\n        else:\n            self.bridge = None\n            \n        self.test_results = []\n        self.received_data = {\n            'laser': [],\n            'camera': None,\n            'imu': [],\n            'imu2': [],\n            'odom': None,\n            'joint_states': None,\n            'battery': None,\n            'dock_state': None,\n            'dock_result': None,\n            'cmd_vel_echo': None\n        }\n        \n        self.project_root = '/home/aidlux/Haier_robot_ws'\n        \n        self.run_all_tests()\n\n    def run_all_tests(self):\n        \"\"\"运行所有测试\"\"\"\n        print(\"\\n\" + \"=\"*60)\n        print(\"    海尔机器人控制系统 - 功能测试开始\")\n        print(\"=\"*60)\n        \n        self.test_environment()\n        self.test_can_interface()\n        self.test_laser()\n        self.test_camera()\n        self.test_imu()\n        self.test_odom()\n        self.test_joint_states()\n        self.test_battery()\n        self.test_chassis_control()\n        self.test_motor_control()\n        self.test_docking()\n        self.test_navigation()\n        \n        self.print_summary()\n\n    def log_result(self, test_name, success, message):\n        status = \"✓ 完成\" if success else \"✗ 失败\"\n        self.test_results.append({\n            'name': test_name,\n            'success': success,\n            'message': message\n        })\n        print(f\"[{status}] {test_name}: {message}\")\n\n    def test_environment(self):\n        \"\"\"测试运行环境\"\"\"\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: 运行环境\")\n        print(\"=\"*50)\n        \n        try:\n            node_name = self.get_name()\n            print(f\"  - ROS2节点: {node_name}\")\n            try:\n                print(f\"  - ROS2版本: {rclpy.__ros_distribution__}\")\n            except:\n                print(f\"  - ROS2版本: humble\")\n            self.log_result(\"运行环境\", True, \"ROS2环境正常\")\n        except Exception as e:\n            self.log_result(\"运行环境\", False, str(e))\n\n    def test_can_interface(self):\n        \"\"\"测试CAN接口\"\"\"\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: CAN总线接口\")\n        print(\"=\"*50)\n        \n        try:\n            import subprocess\n            result = subprocess.run(\n                ['ip', '-details', 'link', 'show', 'can0'],\n                capture_output=True, text=True, timeout=3\n            )\n            if result.returncode == 0 and 'can0' in result.stdout:\n                if 'UP' in result.stdout:\n                    self.log_result(\"CAN总线\", True, \"CAN0接口正常\")\n                    print(f\"  - CAN状态: {result.stdout.split('state')[1].split()[0] if 'state' in result.stdout else 'UP'}\")\n                else:\n                    self.log_result(\"CAN总线\", False, \"CAN0未启动\")\n            else:\n                self.log_result(\"CAN总线\", False, \"未找到CAN0接口\")\n        except Exception as e:\n            self.log_result(\"CAN总线\", False, f\"无法检查CAN状态: {e}\")\n        \n    def log_result(self, test_name, success, message):\n        status = \"✓ 完成\" if success else \"✗ 失败\"\n        self.test_results.append({\n            'name': test_name,\n            'success': success,\n            'message': message\n        })\n        print(f\"[{status}] {test_name}: {message}\")\n\n    def test_laser(self):\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: 激光雷达数据\")\n        print(\"=\"*50)\n        \n        self.laser_sub = self.create_subscription(\n            LaserScan,\n            '/scan',\n            self.laser_callback,\n            10\n        )\n        \n        timeout = 5\n        start_time = time.time()\n        while len(self.received_data['laser']) == 0 and (time.time() - start_time) < timeout:\n            rclpy.spin_once(self, timeout_sec=0.5)\n        \n        if len(self.received_data['laser']) > 0:\n            scan_data = self.received_data['laser'][-1]\n            print(f\"  - 收到激光数据: {len(scan_data.ranges)} 个点\")\n            print(f\"  - 角度范围: {np.rad2deg(scan_data.angle_min):.1f}° ~ {np.rad2deg(scan_data.angle_max):.1f}°\")\n            print(f\"  - 距离范围: {min(scan_data.ranges):.2f}m ~ {max(scan_data.ranges):.2f}m\")\n            \n            valid_ranges = [r for r in scan_data.ranges if not np.isnan(r) and not np.isinf(r)]\n            if valid_ranges:\n                avg_range = np.mean(valid_ranges)\n                print(f\"  - 有效距离均值: {avg_range:.2f}m\")\n            \n            print(f\"\\n  前方5个距离值: {[round(r, 2) for r in scan_data.ranges[:5] if not np.isnan(r)]}\")\n            self.log_result(\"激光雷达\", True, f\"成功接收 {len(scan_data.ranges)} 个激光点\")\n        else:\n            self.log_result(\"激光雷达\", False, \"5秒内未收到激光数据\")\n        \n        self.destroy_subscription(self.laser_sub)\n\n    def laser_callback(self, msg):\n        self.received_data['laser'].append(msg)\n\n    def test_camera(self):\n        \"\"\"测试USB摄像头\"\"\"\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: USB摄像头\")\n        print(\"=\"*50)\n        \n        camera_topics = ['/rear_camera/image_raw', '/usb_cam/image_raw', '/image_raw', '/camera/image_raw']\n        camera_sub = None\n        \n        for topic in camera_topics:\n            try:\n                camera_sub = self.create_subscription(\n                    Image,\n                    topic,\n                    self.camera_callback,\n                    10\n                )\n                print(f\"  - 尝试订阅: {topic}\")\n                break\n            except:\n                continue\n        \n        if camera_sub is None:\n            self.log_result(\"USB摄像头\", False, \"无可用的摄像头话题\")\n            return\n            \n        timeout = 5\n        start_time = time.time()\n        while self.received_data['camera'] is None and (time.time() - start_time) < timeout:\n            rclpy.spin_once(self, timeout_sec=0.5)\n        \n        if self.received_data['camera'] is not None:\n            cv_image = self.received_data['camera']\n            height, width = cv_image.shape[:2]\n            print(f\"  - 图像尺寸: {width} x {height}\")\n            print(f\"  - 通道数: {cv_image.shape[2] if len(cv_image.shape) > 2 else 1}\")\n            \n            save_path = '/home/aidlux/Haier_robot_ws/test_camera_capture.jpg'\n            cv2.imwrite(save_path, cv_image)\n            print(f\"  - 图片已保存: {save_path}\")\n            \n            self.log_result(\"USB摄像头\", True, f\"图像尺寸 {width}x{height}, 已保存到 {save_path}\")\n        else:\n            self.log_result(\"USB摄像头\", False, \"5秒内未收到图像数据\")\n        \n        if camera_sub:\n            self.destroy_subscription(camera_sub)\n\n    def camera_callback(self, msg):\n        try:\n            if self.bridge is not None:\n                self.received_data['camera'] = self.bridge.imgmsg_to_cv2(msg, 'bgr8')\n            else:\n                img_data = np.frombuffer(msg.data, dtype=np.uint8)\n                h = msg.height\n                w = msg.width\n                \n                if msg.encoding in ['rgb8', 'bgr8', 'bgra8', 'rgba8']:\n                    channels = 3 if 'rgb' in msg.encoding or 'bgr' in msg.encoding else 4\n                    self.received_data['camera'] = img_data.reshape((h, w, channels))\n                    if msg.encoding == 'rgb8':\n                        self.received_data['camera'] = cv2.cvtColor(self.received_data['camera'], cv2.COLOR_RGB2BGR)\n                elif msg.encoding in ['mono8', 'mono16']:\n                    self.received_data['camera'] = img_data.reshape((h, w))\n                elif msg.encoding in ['uyvy', 'yuyv']:\n                    self.received_data['camera'] = img_data.reshape((h, w * 2))\n                else:\n                    self.received_data['camera'] = img_data.reshape((h, w))\n        except Exception as e:\n            print(f\"  - 图像解析错误: {e}\")\n\n    def test_imu(self):\n        \"\"\"测试IMU陀螺仪\"\"\"\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: IMU陀螺仪\")\n        print(\"=\"*50)\n        \n        imu_topics = ['/imu/data', '/imu1/data', '/imu_data', '/imu_raw', '/gy95t/imu']\n        imu_sub = None\n        \n        for topic in imu_topics:\n            try:\n                imu_sub = self.create_subscription(\n                    Imu,\n                    topic,\n                    self.imu_callback,\n                    10\n                )\n                print(f\"  - 尝试订阅: {topic}\")\n                break\n            except:\n                continue\n        \n        if imu_sub is None:\n            self.log_result(\"IMU陀螺仪\", False, \"无可用的IMU话题\")\n            return\n        \n        timeout = 3\n        start_time = time.time()\n        while len(self.received_data['imu']) == 0 and (time.time() - start_time) < timeout:\n            rclpy.spin_once(self, timeout_sec=0.5)\n        \n        if len(self.received_data['imu']) > 0:\n            imu_data = self.received_data['imu'][-1]\n            print(f\"  - 加速度 x: {imu_data.linear_acceleration.x:.4f} m/s²\")\n            print(f\"  - 加速度 y: {imu_data.linear_acceleration.y:.4f} m/s²\")\n            print(f\"  - 加速度 z: {imu_data.linear_acceleration.z:.4f} m/s²\")\n            print(f\"  - 角速度 x: {imu_data.angular_velocity.x:.4f} rad/s\")\n            print(f\"  - 角速度 y: {imu_data.angular_velocity.y:.4f} rad/s\")\n            print(f\"  - 角速度 z: {imu_data.angular_velocity.z:.4f} rad/s\")\n            self.log_result(\"IMU陀螺仪\", True, \"成功接收IMU数据\")\n        else:\n            self.log_result(\"IMU陀螺仪\", False, \"3秒内未收到IMU数据\")\n        \n        if imu_sub:\n            self.destroy_subscription(imu_sub)\n\n    def imu_callback(self, msg):\n        self.received_data['imu'].append(msg)\n\n    def test_odom(self):\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: 底盘里程计\")\n        print(\"=\"*50)\n        \n        self.odom_sub = self.create_subscription(\n            Odometry,\n            '/odom',\n            self.odom_callback,\n            10\n        )\n        \n        time.sleep(1)\n        rclpy.spin_once(self, timeout_sec=1)\n        \n        if self.received_data['odom'] is not None:\n            odom = self.received_data['odom']\n            print(f\"  - 位置 x: {odom.pose.pose.position.x:.3f} m\")\n            print(f\"  - 位置 y: {odom.pose.pose.position.y:.3f} m\")\n            print(f\"  - 速度 linear: {odom.twist.twist.linear.x:.3f} m/s\")\n            print(f\"  - 速度 angular: {odom.twist.twist.angular.z:.3f} rad/s\")\n            self.log_result(\"底盘里程计\", True, f\"位置({odom.pose.pose.position.x:.2f}, {odom.pose.pose.position.y:.2f})\")\n        else:\n            self.log_result(\"底盘里程计\", False, \"未收到里程计数据\")\n        \n        self.destroy_subscription(self.odom_sub)\n\n    def odom_callback(self, msg):\n        self.received_data['odom'] = msg\n\n    def test_joint_states(self):\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: 云台电机状态\")\n        print(\"=\"*50)\n        \n        self.joint_sub = self.create_subscription(\n            JointState,\n            '/joint_states',\n            self.joint_callback,\n            10\n        )\n        \n        time.sleep(1)\n        rclpy.spin_once(self, timeout_sec=1)\n        \n        if self.received_data['joint_states'] is not None:\n            joint = self.received_data['joint_states']\n            print(f\"  - 关节数量: {len(joint.name)}\")\n            for i, name in enumerate(joint.name):\n                pos = joint.position[i] if i < len(joint.position) else 0\n                vel = joint.velocity[i] if i < len(joint.velocity) else 0\n                print(f\"  - {name}: 位置={pos:.4f} rad, 速度={vel:.4f} rad/s\")\n            self.log_result(\"云台电机状态\", True, f\"关节数: {len(joint.name)}\")\n        else:\n            self.log_result(\"云台电机状态\", False, \"未收到关节状态数据\")\n        \n        self.destroy_subscription(self.joint_sub)\n\n    def joint_callback(self, msg):\n        self.received_data['joint_states'] = msg\n\n    def test_battery(self):\n        \"\"\"测试电池状态\"\"\"\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: 电池状态\")\n        print(\"=\"*50)\n        \n        battery_topics = ['/battery_state', '/battery_data', '/battery', '/bms/status']\n        battery_sub = None\n        \n        for topic in battery_topics:\n            try:\n                battery_sub = self.create_subscription(\n                    BatteryState,\n                    topic,\n                    self.battery_callback,\n                    10\n                )\n                print(f\"  - 尝试订阅: {topic}\")\n                break\n            except:\n                continue\n        \n        if battery_sub is None:\n            self.log_result(\"电池状态\", False, \"无可用的电池话题\")\n            return\n        \n        time.sleep(1)\n        rclpy.spin_once(self, timeout_sec=1)\n        \n        if self.received_data['battery'] is not None:\n            bat = self.received_data['battery']\n            print(f\"  - 电压: {bat.voltage:.2f} V\")\n            print(f\"  - 电量: {bat.percentage:.1f}%\")\n            print(f\"  - 电流: {bat.current:.2f} A\")\n            print(f\"  - 温度: {bat.temperature:.1f}°C\" if bat.temperature > 0 else \"  - 温度: N/A\")\n            self.log_result(\"电池状态\", True, f\"电压{bat.voltage:.1f}V, 电量{bat.percentage:.0f}%\")\n        else:\n            self.log_result(\"电池状态\", False, \"未收到电池数据\")\n        \n        if battery_sub:\n            self.destroy_subscription(battery_sub)\n\n    def battery_callback(self, msg):\n        self.received_data['battery'] = msg\n\n    def test_chassis_control(self):\n        \"\"\"测试底盘控制\"\"\"\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: 底盘控制\")\n        print(\"=\"*50)\n        \n        self.cmd_vel_pub = self.create_publisher(Twist, '/cmd_vel', 10)\n        \n        test_twist = Twist()\n        test_twist.linear.x = 0.1\n        test_twist.angular.z = 0.0\n        self.cmd_vel_pub.publish(test_twist)\n        print(f\"  - 发布测试速度: linear.x={test_twist.linear.x} m/s\")\n        \n        time.sleep(0.5)\n        \n        stop_twist = Twist()\n        stop_twist.linear.x = 0.0\n        self.cmd_vel_pub.publish(stop_twist)\n        print(f\"  - 发送停止命令\")\n        \n        self.log_result(\"底盘控制\", True, \"已发送测试速度命令\")\n        \n        self.destroy_publisher(self.cmd_vel_pub)\n\n    def test_motor_control(self):\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: 云台电机控制\")\n        print(\"=\"*50)\n        \n        self.motor_pub = self.create_publisher(Float32, '/target_head_position', 10)\n        \n        test_position = 0.3\n        msg = Float32()\n        msg.data = test_position\n        self.motor_pub.publish(msg)\n        print(f\"  - 发布目标位置: {test_position} rad\")\n        \n        time.sleep(1)\n        \n        msg.data = 0.0\n        self.motor_pub.publish(msg)\n        print(f\"  - 复位位置: 0.0 rad\")\n        \n        self.log_result(\"云台电机控制\", True, f\"已发布目标位置 {test_position} rad\")\n        \n        self.destroy_publisher(self.motor_pub)\n\n    def test_navigation(self):\n        \"\"\"测试导航功能\"\"\"\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: 导航功能\")\n        print(\"=\"*50)\n        \n        self.base_link_sub = self.create_subscription(\n            PoseStamped,\n            '/base_link_pose',\n            self.base_link_callback,\n            10\n        )\n        \n        time.sleep(1)\n        rclpy.spin_once(self, timeout_sec=1)\n        \n        self.log_result(\"导航功能\", True, \"订阅位置话题成功\")\n        \n        self.destroy_subscription(self.base_link_sub)\n\n    def base_link_callback(self, msg):\n        pass\n\n    def test_docking(self):\n        print(\"\\n\" + \"=\"*50)\n        print(\"测试: 自动Docking状态\")\n        print(\"=\"*50)\n        \n        self.dock_sub = self.create_subscription(\n            String,\n            '/dock_state',\n            self.dock_callback,\n            10\n        )\n        \n        time.sleep(1)\n        rclpy.spin_once(self, timeout_sec=1)\n        \n        if self.received_data['dock_state'] is not None:\n            state = self.received_data['dock_state'].data\n            print(f\"  - 当前状态: {state}\")\n            self.log_result(\"Docking状态\", True, f\"当前状态: {state}\")\n        else:\n            print(f\"  - 当前状态: 未充电 (默认)\")\n            self.log_result(\"Docking状态\", True, \"未充电 (默认状态)\")\n        \n        self.destroy_subscription(self.dock_sub)\n\n    def dock_callback(self, msg):\n        self.received_data['dock_state'] = msg\n\n    def print_summary(self):\n        print(\"\\n\" + \"=\"*60)\n        print(\"                    测试结果汇总\")\n        print(\"=\"*60)\n        \n        success_count = sum(1 for r in self.test_results if r['success'])\n        total_count = len(self.test_results)\n        \n        for result in self.test_results:\n            status = \"✓\" if result['success'] else \"✗\"\n            print(f\"  {status} {result['name']}: {result['message']}\")\n        \n        print(\"\\n\" + \"-\"*60)\n        print(f\"  总计: {success_count}/{total_count} 项测试通过\")\n        print(\"=\"*60)\n        \n        if success_count == total_count:\n            print(\"\\n🎉 所有测试项目完成!\")\n        else:\n            print(f\"\\n⚠️  {total_count - success_count} 项测试失败，请检查硬件连接\")\n\n\ndef main(args=None):\n    print(\"=\"*60)\n    print(\"    海尔机器人控制系统 - 功能测试脚本\")\n    print(\"=\"*60)\n    print(\"开始ROS2节点测试...\")\n    \n    rclpy.init(args=args)\n    \n    tester = RobotControlTester()\n    rclpy.spin_once(tester, timeout_sec=2)\n    \n    tester.print_summary()\n    \n    tester.destroy_node()\n    rclpy.shutdown()\n\n\nif __name__ == '__main__':\n    main()"}],"isError":false,"timestamp":1774927264383}}
