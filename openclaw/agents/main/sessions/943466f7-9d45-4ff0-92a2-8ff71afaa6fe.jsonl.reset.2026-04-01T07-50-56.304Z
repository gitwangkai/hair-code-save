{"type":"message","id":"30cdc63c","parentId":"6f45222c","timestamp":"2026-03-31T03:36:19.868Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"                                         没有找到这个目录。让我查找这个包的Python文件：","thinkingSignature":""},{"type":"toolCall","id":"tool_8uhb2fAbq00qar2Q3ft4OoMH","name":"read","arguments":{"file_path":"/home/aidlux/Haier_robot_ws/build/hair_arm_control/build/lib.linux-aarch64-cpython-310/hair_arm_control/motor/motor_api_test.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"kimi","model":"kimi-code","usage":{"input":51087,"output":57,"cacheRead":0,"cacheWrite":0,"totalTokens":51144,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774928168303,"responseId":"msg_D5NYBXNVdEYY0PaP8QV4t7Q3"}}
{"type":"message","id":"69e677f1","parentId":"30cdc63c","timestamp":"2026-03-31T03:36:19.900Z","message":{"role":"toolResult","toolCallId":"tool_8uhb2fAbq00qar2Q3ft4OoMH","toolName":"read","content":[{"type":"text","text":"import sys\nimport time\nimport select\nimport threading\nfrom dataclasses import dataclass\nfrom typing import List, Dict\n\nimport rclpy\nfrom rclpy.node import Node\nfrom rclpy.action import ActionClient\nfrom action_msgs.msg import GoalStatus\nfrom pynput import keyboard\n\nfrom arm_control_interface.action import ArmMove\nfrom arm_control_interface.srv import SetPower\n\n\n@dataclass\nclass JointPose:\n    \"\"\"机械臂 7 轴姿态 (弧度)\"\"\"\n    j1: float = 0.0; j2: float = 0.0; j3: float = 0.0\n    j4: float = 0.0; j5: float = 0.0; j6: float = 0.0\n\n    def to_list(self) -> List[float]:\n        return [self.j1, self.j2, self.j3, self.j4, self.j5, self.j6]\n\n# --- 2. 动作库配置 ---\nACTION_LIBRARY: Dict[str, List[JointPose]] = {\n    \"HOME\": [JointPose()],\n    \"WAVE_HAND\": [\n        JointPose(),\n        JointPose(j1=0.459),\n        JointPose(j1=0.459, j2=0.351),\n        JointPose(j1=-0.305, j2=0.351, j4=0.488),\n        JointPose()\n    ]\n}\n\nACTION_NAMES = list(ACTION_LIBRARY.keys())\n\nclass RobotMoveApp(Node):\n    def __init__(self, ns=\"wy_robot1\"):\n        super().__init__(f\"{ns}_move_app\")\n        self.ns = ns\n        \n        # Action 客户端初始化\n        self._action_client = ActionClient(self, ArmMove, self._topic(\"A6_move_action\"))\n        self._power_client = self.create_client(SetPower, self._topic('A6_set_power'))\n        self._goal_handle = None\n        \n \n        self.stop_current_action = False\n        self.exit_program = False\n        self.is_waiting_result = False\n        self.last_action_succeeded = False\n\n\n\n    def start(self):\n        self.get_logger().info(\"正在连接 ArmMove Action 服务器...\")\n        if not self._action_client.wait_for_server(timeout_sec=3.0):\n            self.get_logger().info(\"无法连接到 Action 服务器！\")\n            sys.exit(1)\n\n        self.get_logger().info(\"正在连接 Power 服务...\")\n        if not self._power_client.wait_for_service(timeout_sec=3.0):\n            self.get_logger().info(\"无法连接到 Power 服务！\")\n            sys.exit(1)\n\n        for i in range(0, 3):\n            if not rclpy.ok():\n                break\n                \n            req = SetPower.Request()\n            req.power_enable = True\n            \n            future = self._power_client.call_async(req)\n            \n            while rclpy.ok() and not future.done():\n                time.sleep(0.1) \n            \n            if future.done() and future.result():\n                self.get_logger().info(f\"电源使能尝试 {i+1} 成功\")\n            \n            start_sleep = time.time()\n            while rclpy.ok() and (time.time() - start_sleep) < 0.5:\n                time.sleep(0.1)\n\n        if rclpy.ok():\n            self.get_logger().info(\"所有连接已建立，准备就绪！\")\n   \n\n\n    def _topic(self, name: str) -> str:\n        return f\"/{self.ns}/{name}\"\n\n    def send_move_goal_sync(self, pose: JointPose):\n        \"\"\"发送目标并阻塞等待结果（直到完成或被手动中断）\"\"\"\n        goal_msg = ArmMove.Goal()\n        goal_msg.move_type = \"MoveJ\" # 默认使用 MoveJ\n        goal_msg.joint_angles = pose.to_list()\n\n        self.is_waiting_result = True\n        self.last_action_succeeded = False\n        \n        self.get_logger().info(f\"发送点位: {goal_msg.joint_angles}\")\n        \n        send_goal_future = self._action_client.send_goal_async(goal_msg)\n        send_goal_future.add_done_callback(self._goal_response_callback)\n\n        while self.is_waiting_result and rclpy.ok():\n            if self.stop_current_action:\n                self.cancel_current_goal()\n                break\n            time.sleep(0.1)\n        \n        return self.last_action_succeeded\n\n    def _goal_response_callback(self, future):\n        self._goal_handle = future.result()\n        if not self._goal_handle.accepted:\n            self.get_logger().info(\"目标被服务器拒绝\")\n            self.is_waiting_result = False\n            return\n\n        result_future = self._goal_handle.get_result_async()\n        result_future.add_done_callback(self._result_callback)\n\n    def _result_callback(self, future):\n        status = future.result().status\n        if status == GoalStatus.STATUS_SUCCEEDED:\n            self.last_action_succeeded = True\n            self.get_logger().info(\"到达点位成功\")\n        else:\n            self.last_action_succeeded = False\n            self.get_logger().warn(f\"动作结束，状态码: {status}\")\n            \n        self.is_waiting_result = False\n        self._goal_handle = None\n\n    def cancel_current_goal(self):\n        if self._goal_handle:\n            self.get_logger().warn(\"正在取消当前动作...\")\n            self._goal_handle.cancel_goal_async()\n\n    def _on_press(self, key):\n        try:\n            if key.char == 's':\n                self.stop_current_action = True\n            elif key.char == 'q':\n                self.stop_current_action = True\n                self.exit_program = True\n        except: pass\n\n    def run_sequence(self, name: str, repeat_times: int):\n        poses = ACTION_LIBRARY.get(name)\n        self.stop_current_action = False\n        count = 0\n        \n        while not self.stop_current_action:\n            count += 1\n            if repeat_times > 0 and count > repeat_times: break\n            \n            print(f\"\\n>> 正在执行序列: {name} (轮次: {count}/{repeat_times if repeat_times > 0 else '∞'})\")\n            \n            for idx, pose in enumerate(poses):\n                if self.stop_current_action: break\n                print(f\"  - 移动中... 点位 {idx+1}/{len(poses)}\")\n                \n                success = self.send_move_goal_sync(pose)\n                if not success and not self.stop_current_action:\n                    print(\"  [警告] 点位执行未成功，跳向下一个\")\n                \n                time.sleep(0.1) \n\n    def _get_input(self, prompt: str) -> str:\n        sys.stdout.write(prompt)\n        sys.stdout.flush()\n        while rclpy.ok() and not self.exit_program:\n            r, _, _ = select.select([sys.stdin], [], [], 0.1)\n            if r: return sys.stdin.readline().strip()\n        return \"q\"\n\n    def main_menu(self):\n        # 启动按键监听\n        listener = keyboard.Listener(on_press=self._on_press)\n        listener.start()\n\n        while rclpy.ok() and not self.exit_program:\n            print(\"\\n\" + \"=\"*30)\n            for i, name in enumerate(ACTION_NAMES):\n                print(f\"{i+1:<4} | {name}\")\n            print(\"-\" * 30 + \"\\n[s] 中断 | [q] 退出\")\n            \n            sel = self._get_input(\"请选择序号: \")\n            \n            if self.exit_program or sel.lower() == 'q': break\n            if not sel.isdigit(): continue\n            \n            idx = int(sel) - 1\n            if 0 <= idx < len(ACTION_NAMES):\n                raw_times = self._get_input(\"循环次数 (0无限): \")\n                try:\n                    t = int(raw_times) if raw_times else 1\n                except: t = 1\n                \n                self.run_sequence(ACTION_NAMES[idx], t)\n\n        listener.stop()\n        print(\"程序已退出\")\n\n\ndef main():\n    rclpy.init()\n    app = RobotMoveApp(ns=\"wy_robot1\")\n    \n    spin_thread = threading.Thread(target=lambda: rclpy.spin(app), daemon=True)\n    spin_thread.start()\n\n    try:\n        app.start()\n        app.main_menu()\n    except KeyboardInterrupt:\n        pass\n\nif __name__ == '__main__':\n    main()"}],"isError":false,"timestamp":1774928179891}}
